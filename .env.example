DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
PORT=5000
# Generate a strong random value, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret
FLASK_DEBUG=0

# Note: channel_binding=require enforces SCRAM authentication with proper SSL.
# Neon supports this. For other providers, you may omit it: ?sslmode=require
